\"c3195db4-ca05-4804-836b-721f3f622e9d\") format('woff2');\n  unicode-range: U+0102-0103, U+0110-0111, U+0128-0129, U+0168-0169, U+01A0-01A1, U+01AF-01B0, U+0300-0301, U+0303-0304, U+0308-0309, U+0323, U+0329, U+1EA0-1EF9, U+20AB;\n}\n/* latin-ext */\n@font-face {\n  font-family: 'Barlow Condensed';\n  font-style: normal;\n  font-weight: 700;\n  font-display: swap;\n  src: url(\"9bd7b990-0e25-4206-a4f2-70426f1a4ea0\") format('woff2');\n  unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF;\n}\n/* latin */\n@font-face {\n  font-family: 'Barlow Condensed';\n  font-style: normal;\n  font-weight: 700;\n  font-display: swap;\n  src: url(\"97d7c287-9c76-4c4d-92d7-5fe78dd2d6ed\") format('woff2');\n  unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;\n}\n</style>\n<style>\nbody{margin:0;background:#070d20;display:grid;place-items:center;min-height:100vh;font-family:'Barlow Condensed',sans-serif}\n.plugin{width:760px;height:560px;background:radial-gradient(130% 100% at 50% -10%,#1a2f6b 0%,#101f4a 48%,#0d1b3d 100%);border-radius:12px;position:relative;overflow:hidden;color:#f5f5f5;box-shadow:0 30px 70px rgba(0,0,0,.65),inset 0 1px 0 rgba(140,170,230,.25);border:1px solid #2a3f7d;user-select:none;--gold:#D4A017}\n.burst{position:absolute;inset:-40%;background:repeating-conic-gradient(from 0deg at 50% 30%,rgba(117,170,219,.05) 0 6deg,transparent 6deg 12deg);pointer-events:none}\n.tex{position:absolute;inset:0;background:repeating-linear-gradient(45deg,rgba(0,0,0,.14) 0 2px,transparent 2px 4px),repeating-linear-gradient(-45deg,rgba(0,0,0,.1) 0 2px,transparent 2px 4px);opacity:.5;pointer-events:none}\n.screw{position:absolute;width:14px;height:14px;border-radius:50%;background:radial-gradient(circle at 35% 30%,#9fb0cc,#3c4a6b 65%,#1a2340);box-shadow:0 1px 2px rgba(0,0,0,.7)}\n.screw:before{content:\"\";position:absolute;left:2px;right:2px;top:6px;height:2px;background:#141c33;transform:rotate(28deg)}\n.stars{color:#FFD700;font-size:15px;letter-spacing:8px;text-shadow:0 0 8px rgba(255,215,0,.55)}\n.title{font-family:Anton,sans-serif;font-size:44px;letter-spacing:4px;line-height:1;color:#f5f5f5;text-shadow:0 0 2px #75AADB,0 0 14px rgba(117,170,219,.55),3px 3px 0 #0a1430;margin:2px 0 0}\n.sub{color:#75AADB;font-size:14px;letter-spacing:3px;font-weight:600}\n.pcard{background:linear-gradient(180deg,#13234f,#0e1a3c);border:2px solid #253a72;border-radius:12px;padding:8px 6px 7px;width:134px;cursor:pointer;color:#f5f5f5;font-family:inherit;transition:border-color .15s,box-shadow .15s,filter .15s;filter:saturate(.35) brightness(.75)}\n.pcard.on{border-color:var(--gold);box-shadow:0 0 14px rgba(212,160,23,.45),inset 0 0 10px rgba(212,160,23,.15);filter:none}\n.face{width:86px;height:86px;border-radius:50%;margin:0 auto;background-color:#0a1430;background-size:cover;background-position:center 15%;background-repeat:no-repeat;border:2px solid #33488a;box-shadow:inset 0 0 12px rgba(0,0,0,.5)}\n.pcard.on .face{border-color:#FFD700}\n.pname{font-weight:700;font-size:17px;letter-spacing:1.5px;margin-bottom:5px}\n.palgo{font-size:11.5px;letter-spacing:2px;color:#75AADB;font-weight:600;margin-top:5px}\n.pcard.on .palgo{color:#FFD700}\n.knob{width:82px;text-align:center;cursor:ns-resize}\n.kbody{width:64px;height:64px;border-radius:50%;margin:0 auto;position:relative;background:radial-gradient(circle at 35% 28%,#ffffff,#e9e9e9 55%,#c9c9c9);box-shadow:0 4px 10px rgba(0,0,0,.6),inset 0 2px 3px rgba(255,255,255,.8),inset 0 -4px 8px rgba(0,0,0,.18)}\n.ball{position:absolute;inset:0;border-radius:50%;overflow:hidden;background:url(\"83b278ef-4151-49cc-8d75-578c39487912\") center/180% no-repeat}\n.karc{position:absolute;inset:-7px;border-radius:50%;-webkit-mask:radial-gradient(closest-side,transparent 82%,#000 84%);mask:radial-gradient(closest-side,transparent 82%,#000 84%)}\n.kind{position:absolute;left:50%;top:50%;width:4px;height:32px;margin-left:-2px;transform-origin:50% 0}\n.kind span{position:absolute;left:0;top:7px;width:4px;height:18px;border-radius:2px;background:#C0392B;box-shadow:0 0 6px rgba(192,57,43,.8)}\n.klabel{font-size:13px;font-weight:700;letter-spacing:2.5px;margin-top:8px;color:#c8d4ee}\n.kval{font-size:12px;color:#75AADB;font-weight:600}\n.garra{width:64px;height:64px;border-radius:50%;border:3px solid #6b5410;cursor:pointer;font-family:Anton,sans-serif;font-size:13px;letter-spacing:2px;color:#ffd9b0;background:radial-gradient(circle at 40% 32%,#a03328,#6e1f16 60%,#4a130d);box-shadow:0 6px 0 #401009,0 10px 18px rgba(0,0,0,.6);transition:all .12s}\n.garra.on{background:radial-gradient(circle at 40% 32%,#ff7b3d,#d43a1f 55%,#8a1f10);color:#fff;text-shadow:0 0 10px #ffb347;box-shadow:0 3px 0 #401009,0 0 26px rgba(255,120,40,.85),0 0 60px rgba(255,160,40,.4);transform:translateY(3px);border-color:var(--gold)}\n.gwrap{width:110px}\n.glabel{font-size:12px;letter-spacing:2px;color:#c8d4ee;font-weight:600;margin-top:10px}\n.meter{width:210px;height:104px;background:url(\"45b912f4-c1e3-4bc5-a785-7a1b7f9d0aa8\") center/cover;border-radius:8px;position:relative;overflow:hidden;box-shadow:inset 0 0 14px rgba(60,40,0,.3),0 3px 8px rgba(0,0,0,.5);border:3px solid #1a2340}\n.tick{position:absolute;left:50%;top:96px;width:0;height:0}\n.tick i{position:absolute;left:-1px;top:-88px;width:2px;height:8px;background:#eaf5e6;display:block}\n.tick.red i{background:#ff5d47}\n.tick b{position:absolute;left:-9px;top:-107px;width:18px;text-align:center;font-size:10px;font-weight:700;color:#eaf5e6;font-family:'Barlow Condensed',sans-serif}\n.tick.red b{color:#ff5d47}\n.redarc{position:absolute;left:50%;top:96px;width:176px;height:176px;margin:-88px 0 0 -88px;border-radius:50%;background:conic-gradient(from 33deg,#ff5d47 0 15deg,transparent 15deg);-webkit-mask:radial-gradient(closest-side,transparent 92%,#000 94%);mask:radial-gradient(closest-side,transparent 92%,#000 94%)}\n.needle{position:absolute;left:50%;top:0;width:96px;height:96px;margin-left:-48px;transform-origin:50% 96px;transform:rotate(-48deg)}\n.copa{display:block;width:96px;height:92px;object-fit:contain;margin:0 auto;filter:drop-shadow(0 1px 3px rgba(0,30,0,.55))}\n.pivot{position:absolute;left:50%;top:88px;width:16px;height:16px;margin-left:-8px;border-radius:50%;background:radial-gradient(circle at 35% 30%,#555,#111)}\n.vulabel{position:absolute;left:0;right:0;top:66px;text-align:center;font-size:11px;letter-spacing:3px;font-weight:700;color:#bfe3b8}\n.footer{font-size:11px;letter-spacing:2px;color:#3d5493;font-weight:600}\n</style>\n</helmet>\n<div class=\"plugin posrel\" ref=\"{{rootRef}}\">\n<div class=\"burst\"></div>\n<sc-if value=\"{{texOn}}\" hint-placeholder-val=\"{{false}}\"><div class=\"tex\"></div></sc-if>\n<div class=\"screw\" style=\"top:8px;left:8px\"></div><div class=\"screw\" style=\"top:8px;right:8px\"></div><div class=\"screw\" style=\"bottom:8px;left:8px\"></div><div class=\"screw\" style=\"bottom:8px;right:8px\"></div>\n<div class=\"col ac posrel\" style=\"padding-top:18px\">\n<div class=\"stars\">\u2605 \u2605 \u2605</div>\n<h1 class=\"title m0\">LA DISTORNETA</h1>\n<div class=\"sub upper\">Distorsi\u00f3n Campeona del Mundo</div>\n</div>\n<div class=\"fx jc gap10 posrel\" style=\"margin-top:16px\">\n<button class=\"pcard {{p1}}\" onclick=\"{{sel1}}\"><div class=\"pname\">DIBU</div><div class=\"face\" style=\"background-image:url(&quot;07552115-3a9a-48f2-b5ad-b406c6846f31&quot;)\"></div><div class=\"palgo upper\">Fuzz</div></button>\n<button class=\"pcard {{p2}}\" onclick=\"{{sel2}}\"><div class=\"pname\">JULI\u00c1N</div><div class=\"face\" style=\"background-image:url(&quot;56598845-520e-4cf3-9298-d815894bd9e8&quot;)\"></div><div class=\"palgo upper\">Overdrive</div></button>\n<button class=\"pcard {{p0}}\" onclick=\"{{sel0}}\"><div class=\"pname\">MESSI</div><div class=\"face\" style=\"background-image:url(&quot;31bc5339-5d8c-46fc-9a94-c5b7c2f91933&quot;);background-size:150%;background-position:center 30%\"></div><div class=\"palgo upper\">Valvular</div></button>\n<button class=\"pcard {{p3}}\" onclick=\"{{sel3}}\"><div class=\"pname\">LAUTARO</div><div class=\"face\" style=\"background-image:url(&quot;13f46828-cded-45c4-979d-5b03c0350f58&quot;)\"></div><div class=\"palgo upper\">Hard Clip</div></button>\n<button class=\"pcard {{p4}}\" onclick=\"{{sel4}}\"><div class=\"pname\">DE PAUL</div><div class=\"face\" style=\"background-image:url(&quot;a1f8775c-d919-4dd2-a5c8-0243c1010846&quot;)\"></div><div class=\"palgo upper\">Bit Crush</div></button>\n</div>\n<div class=\"fx ac jc gap24 posrel\" style=\"margin-top:28px\">\n<div class=\"col ac posabs\" style=\"left:36px;top:50%;transform:translateY(-50%)\">\n<button class=\"garra {{gOn}}\" onclick=\"{{toggleGarra}}\">GARRA</button>\n<div class=\"glabel upper\" style=\"margin-top:14px\">Modo Bestia</div>\n</div>\n<sc-for list=\"{{knobs}}\" as=\"k\" hint-placeholder-count=\"4\">\n<div class=\"knob\" onpointerdown=\"{{k.down}}\">\n<div class=\"kbody\">\n<div class=\"ball\" style=\"{{k.ind}}\"></div>\n<div class=\"karc\" style=\"{{k.arc}}\"></div>\n<div class=\"kind\" style=\"{{k.ind}}\"><span></span></div>\n</div>\n<div class=\"klabel\">{{k.label}}</div>\n<div class=\"kval\">{{k.pct}}</div>\n</div>\n</sc-for>\n</div>\n<div class=\"fx jc ac gap24 posrel\" style=\"margin-top:24px\">\n<div class=\"meter\">\n<div class=\"redarc\"></div>\n<sc-for list=\"{{ticks}}\" as=\"t\" hint-placeholder-count=\"6\"><div class=\"tick {{t.cls}}\" style=\"{{t.st}}\"><i></i></div></sc-for>\n<div class=\"vulabel\">VU \u00b7 L</div>\n<div class=\"needle\" ref=\"{{lRef}}\"><img class=\"copa\" src=\"afe58e41-b439-43c3-bc4a-d1cb3054cdeb\" alt=\"\"></div>\n<div class=\"pivot\"></div>\n</div>\n<div class=\"col ac\">\n<div class=\"footer upper\" style=\"color:var(--gold)\">HERBAL.BEATS.AUDIO</div>\n</div>\n<div class=\"meter\">\n<div class=\"redarc\"></div>\n<sc-for list=\"{{ticks}}\" as=\"t\" hint-placeholder-count=\"6\"><div class=\"tick {{t.cls}}\" style=\"{{t.st}}\"><i></i></div></sc-for>\n<div class=\"vulabel\">VU \u00b7 R</div>\n<div class=\"needle\" ref=\"{{rRef}}\"><img class=\"copa\" src=\"afe58e41-b439-43c3-bc4a-d1cb3054cdeb\" alt=\"\"></div>\n<div class=\"pivot\"></div>\n</div>\n</div>\n</div>\n</x-dc>\n\n<script type=\"text/x-dc\" data-dc-script=\"\" data-props=\"{&quot;$preview&quot;:{&quot;width&quot;:800,&quot;height&quot;:560},&quot;gold&quot;:{&quot;editor&quot;:&quot;color&quot;,&quot;default&quot;:&quot;#D4A017&quot;,&quot;options&quot;:[&quot;#D4A017&quot;,&quot;#FFD700&quot;,&quot;#E8B923&quot;,&quot;#B8860B&quot;],&quot;tsType&quot;:&quot;string&quot;,&quot;section&quot;:&quot;Estilo&quot;},&quot;texture&quot;:{&quot;editor&quot;:&quot;boolean&quot;,&quot;default&quot;:true,&quot;tsType&quot;:&quot;boolean&quot;,&quot;section&quot;:&quot;Estilo&quot;}}\">\n// ---- puente JUCE (setParam / getState) ----\nlet __juceResultId = 0;\nconst __jucePending = new Map();\nif (window.__JUCE__) {\n  window.__JUCE__.backend.addEventListener('__juce__complete', ({ promiseId, result }) => {\n    const resolve = __jucePending.get(promiseId);\n    if (resolve) { resolve(result); __jucePending.delete(promiseId); }\n  });\n}\nfunction juceSetParam(id, norm) {\n  if (!window.__JUCE__) return;\n  window.__JUCE__.backend.emitEvent('__juce__invoke', { name: 'setParam', params: [id, norm], resultId: __juceResultId++ });\n}\nfunction juceGetState() {\n  if (!window.__JUCE__) return Promise.resolve(null);\n  return new Promise(resolve => {\n    const id = __juceResultId++;\n    __jucePending.set(id, resolve);\n    window.__JUCE__.backend.emitEvent('__juce__invoke', { name: 'getState', params: [], resultId: id });\n  });\n}\n\nclass Component extends DCLogic {\n  state = { player: 0, garra: false, vals: { drive: .65, tone: .5, mix: 1, output: .5 } };\n  componentDidMount() {\n    this.lA = -48; this.rA = -48;\n    const toA = db => -48 + ((db + 20) / 23) * 96;\n    const linToDb = lvl => 20 * Math.log10(Math.max(lvl, 0.0008));\n    const poll = async () => {\n      const st = await juceGetState();\n      if (st) {\n        const dbL = Math.min(6, linToDb(st.levelL || 0));\n        const dbR = Math.min(6, linToDb(st.levelR || 0));\n        this.lA += (toA(dbL) - this.lA) * .3;\n        this.rA += (toA(dbR) - this.rA) * .3;\n        if (this.ln) this.ln.style.transform = `rotate(${this.lA}deg)`;\n        if (this.rn) this.rn.style.transform = `rotate(${this.rA}deg)`;\n        if (!this._synced) {\n          this._synced = true;\n          this.setState({\n            player: Math.round(st.type) || 0,\n            garra: !!st.garra,\n            vals: { drive: st.drive, tone: st.tone, mix: st.mix, output: st.output }\n          });\n        }\n      }\n      this.pollTimer = setTimeout(poll, 33);\n    };\n    poll();\n    this.applyGold();\n  }\n  componentWillUnmount() { clearTimeout(this.pollTimer); }\n  componentDidUpdate() { this.applyGold(); }\n  applyGold() { if (this.root) this.root.style.setProperty('--gold', this.props.gold ?? '#D4A017'); }\n  knobDown(key) {\n    return e => {\n      e.preventDefault();\n      const startY = e.clientY, startV = this.state.vals[key];\n      const move = ev => {\n        const v = Math.max(0, Math.min(1, startV + (startY - ev.clientY) / 140));\n        this.setState(s => ({ vals: { ...s.vals, [key]: v } }));\n        juceSetParam(key, v);\n      };\n      const up = () => { window.removeEventListener('pointermove', move); window.removeEventListener('pointerup', up); };\n      window.addEventListener('pointermove', move);\n      window.addEventListener('pointerup', up);\n    };\n  }\n  renderVals() {\n    const p = this.state.player;\n    const labels = { drive: 'DRIVE', tone: 'TONE', mix: 'MIX', output: 'OUTPUT' };\n    if (!this._downs) { this._downs = {}; for (const k in labels) this._downs[k] = this.knobDown(k); }\n    const knobs = Object.keys(labels).map(k => {\n      const v = this.state.vals[k];\n      let disp = Math.round(v * 100) + '%';\n      if (k === 'output') {\n        if (v === 0) disp = '-\u221e dB';\n        else { const db = 20 * Math.log10(v) + 6; disp = (db >= 0 ? '+' : '') + db.toFixed(1) + ' dB'; }\n      }\n      return {\n        label: labels[k],\n        pct: disp,\n        down: this._downs[k],\n        ind: { transform: `rotate(${-135 + v * 270}deg)` },\n        arc: { background: `conic-gradient(from 225deg, var(--gold) 0 ${v * 270}deg, rgba(255,255,255,.07) ${v * 270}deg 270deg, transparent 270deg)` }\n      };\n    });\n    const toA = db => -48 + ((db + 20) / 23) * 96;\n    const ticks = [-20, -10, -7, -5, -3, -1, 0, 1, 2, 3].map(db => ({\n      st: { transform: `rotate(${toA(db)}deg)` },\n      cls: db >= 0 ? 'red' : '',\n      label: (db === -7 || db === -1 || db === 1 || db === 2) ? '' : (db > 0 ? '+' + db : '' + db)\n    }));\n    const sels = {};\n    for (let i = 0; i < 5; i++) {\n      sels['p' + i] = p === i ? 'on' : '';\n      sels['sel' + i] = () => { this.setState({ player: i }); juceSetParam('type', i / 4); };\n    }\n    return {\n      ...sels, knobs, ticks,\n      gOn: this.state.garra ? 'on' : '',\n      toggleGarra: () => {\n        const g = !this.state.garra;\n        this.setState({ garra: g });\n        juceSetParam('garra', g ? 1 : 0);\n      },\n      texOn: this.props.texture ?? true,\n      rootRef: el => { this.root = el; this.applyGold(); },\n      lRef: el => { this.ln = el; },\n      rRef: el => { this.rn = el; }\n    };\n  }\n}\n<\/script>\n\n\n</body></html>"</script>
</body>
</html>